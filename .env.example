GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Tenor v2 API key for the chat GIF picker. Get one free at
# https://developers.google.com/tenor/guides/quickstart. Without this the GIF
# button in chat shows a "set EXPO_PUBLIC_TENOR_API_KEY" message.
EXPO_PUBLIC_TENOR_API_KEY=your-tenor-key

# Main API base URL — needed for chat send/upload + history fetch.
EXPO_PUBLIC_API_MAIN_URL=https://your-main-api-url
